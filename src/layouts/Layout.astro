---
const { title } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: linear-gradient(180deg, #eef2ff 0%, #f8fafc 100%);
        color: #0f172a;
      }

      .page {
        display: grid;
        place-items: center;
        min-height: 100vh;
        padding: 2rem;
      }

      .card {
        width: min(100%, 920px);
        background: #ffffff;
        border-radius: 32px;
        box-shadow: 0 24px 80px rgba(15, 23, 42, 0.12);
        padding: 3rem;
      }

      .content {
        display: grid;
        gap: 1rem;
      }

      a.button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 1.5rem;
        border-radius: 999px;
        background: #2563eb;
        color: white;
        text-decoration: none;
        font-weight: 700;
      }

      a.button:hover {
        background: #1d4ed8;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="card">
        <div class="content">
          <slot />
        </div>
      </div>
    </div>
  </body>
</html>
